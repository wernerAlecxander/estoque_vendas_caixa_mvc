generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model clientes {
  id                          String                        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome_cliente                String                        @unique @db.VarChar(100)
  cpf_cliente                 String                        @unique @db.VarChar(14)
  endereco_cliente            String?                       @db.VarChar(200)
  bairro_cliente              String?                       @db.VarChar(100)
  cep_cliente                 String                        @default("69.300-000") @db.VarChar(9)
  cidade_cliente              String?                       @default("Boa Vista") @db.VarChar(100)
  telefone_cliente            String?                       @db.VarChar(20)
  data_nascimento             DateTime?                     @db.Date
  email_cliente               String                        @unique @db.VarChar(100)
  data_cadastro               DateTime?                     @default(now()) @db.Timestamp(6)
  pedidos_vendas              pedidos_vendas[]
  servico_manutencao          servico_manutencao[]
  sucata_compras              sucata_compras[]
  veiculos_cliente_manutencao veiculos_cliente_manutencao[]
}

model compatibilidade_pecas {
  id               String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  peca_id          String       @db.Uuid
  modelo_origem_id Int
  ano_inicio       Int?
  ano_fim          Int?
  modelos          modelos      @relation(fields: [modelo_origem_id], references: [id], onUpdate: Restrict, map: "fk_compativel_peca_modelo_marca")
  peca_estoque     peca_estoque @relation(fields: [peca_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_peca_compativel")

  @@unique([peca_id, ano_inicio, ano_fim], map: "uc_peca_modelo")
}

model despesas {
  id                    String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  descricao_despesa     String             @db.VarChar(200)
  valor_despesa         Decimal            @db.Decimal(10, 2)
  data_despesa          DateTime?          @default(now()) @db.Timestamp(6)
  responsavel_compra_id String             @db.Uuid
  categoria_despesa     categoria_despesas
  usuarios              usuarios           @relation(fields: [responsavel_compra_id], references: [id], onUpdate: Restrict, map: "fk_responsavel_despesa")
}

model estoque_objetos_duraveis {
  id                    String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  objeto_duravel        String?   @db.VarChar(100)
  data_compra           DateTime? @default(now()) @db.Timestamp(6)
  data_descarte         DateTime? @default(now()) @db.Timestamp(6)
  responsavel_compra_id String    @db.Uuid
  usuarios              usuarios  @relation(fields: [responsavel_compra_id], references: [id], onUpdate: Restrict, map: "fk_responsavel_compra")
}

model estoque_objetos_genericos {
  id                            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  objeto_descartavel_nome       String?   @unique(map: "uc_objeto_descartavel") @db.VarChar(100)
  preco_objeto_descartavel      Decimal   @default(0.00) @db.Decimal(10, 2)
  quantidade_objeto_descartavel Int       @default(1)
  data_cadastro                 DateTime? @default(now()) @db.Timestamp(6)
  data_uso                      DateTime? @default(now()) @db.Timestamp(6)
  responsavel_compra_id         String    @db.Uuid
  usuarios                      usuarios  @relation(fields: [responsavel_compra_id], references: [id], onUpdate: Restrict, map: "fk_responsavel_compra")
}

model itens_pedido_vendas {
  id                String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  pedido_venda_id   String         @db.Uuid
  peca_estoque_id   String         @unique @db.Uuid
  valor_venda       Decimal        @db.Decimal(10, 2)
  data_fim_garantia DateTime       @db.Date
  status_item       status_item    @default(Disponivel)
  data_devolucao    DateTime?      @db.Timestamp(6)
  motivo_devolucao  String?        @db.VarChar(500)
  peca_estoque      peca_estoque   @relation(fields: [peca_estoque_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_peca_venda")
  pedidos_vendas    pedidos_vendas @relation(fields: [pedido_venda_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_pedido_venda")
}

model modelos {
  id                          Int                           @id @default(autoincrement())
  marca_veiculo               marca_veiculo
  nome_modelo                 String                        @unique @db.VarChar(100)
  compatibilidade_pecas       compatibilidade_pecas[]
  peca_estoque                peca_estoque[]
  sucata_estoque              sucata_estoque[]
  veiculos_cliente_manutencao veiculos_cliente_manutencao[]

  @@unique([marca_veiculo, nome_modelo], map: "uk_marca_modelo")
}

model peca_estoque {
  id                    String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  veiculo_origem_id     String                  @db.Uuid
  nome_peca             String                  @db.VarChar(100)
  modelo_origem_id      Int
  categoria             categoria_peca
  preco                 Decimal                 @default(0.00) @db.Decimal(10, 2)
  status_peca           status_item             @default(Disponivel)
  responsavel_compra_id String                  @db.Uuid
  localizacao_peca      localizacao_peca
  setor_prateleira      setor_prateleira
  data_cadastro         DateTime?               @default(now()) @db.Timestamp(6)
  compatibilidade_pecas compatibilidade_pecas[]
  itens_pedido_vendas   itens_pedido_vendas?
  modelos               modelos                 @relation(fields: [modelo_origem_id], references: [id], onUpdate: Restrict, map: "fk_modelo_origem_id_pecas")
  usuarios              usuarios                @relation(fields: [responsavel_compra_id], references: [id], onUpdate: Restrict, map: "fk_responsavel_compra_id")
  sucata_estoque        sucata_estoque          @relation(fields: [veiculo_origem_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_veiculo_origem_id_veiculo_sucata")
  peca_imagens          peca_imagens[]

  @@unique([veiculo_origem_id, modelo_origem_id, nome_peca], map: "uc_peca_modelo_origem")
  @@index([nome_peca, categoria], map: "idx_pecas_nome_categoria")
}

model peca_imagens {
  id            String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  peca_id       String       @db.Uuid
  url_imagem    String
  principal     Boolean?     @default(false)
  data_cadastro DateTime?    @default(now()) @db.Timestamp(6)
  peca_estoque  peca_estoque @relation(fields: [peca_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_peca_id")
}

model pedidos_vendas {
  id                   String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cliente_comprador_id String                @db.Uuid
  responsavel_venda_id String                @db.Uuid
  data_venda           DateTime              @default(now()) @db.Timestamp(6)
  valor_total          Decimal               @default(0.00) @db.Decimal(10, 2)
  metodo_pagamento     metodo_pagamento      @default(Pix)
  status_pedido        status_pedido         @default(Autorizado)
  observacoes_recibo   String?               @db.VarChar(500)
  itens_pedido_vendas  itens_pedido_vendas[]
  clientes             clientes              @relation(fields: [cliente_comprador_id], references: [id], onUpdate: Restrict, map: "fk_cliente_comprador_id")
  usuarios             usuarios              @relation(fields: [responsavel_venda_id], references: [id], onUpdate: Restrict, map: "fk_responsavel_venda")
}

model servico_manutencao {
  id                          String                      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  categoria_servico           categoria_peca
  descricao_manutencao        String
  veiculo_manutencao_id       String                      @db.Uuid
  cliente_id                  String                      @db.Uuid
  data_manutencao             DateTime?                   @default(now()) @db.Timestamp(6)
  responsavel_id              String                      @db.Uuid
  status_manutencao           status_manutencao           @default(Pendente)
  preco                       Decimal                     @db.Decimal(10, 2)
  clientes                    clientes                    @relation(fields: [cliente_id], references: [id], onUpdate: Restrict, map: "fk_cliente_manutencao")
  usuarios                    usuarios                    @relation(fields: [responsavel_id], references: [id], onUpdate: Restrict, map: "fk_responsavel_manutencao")
  veiculos_cliente_manutencao veiculos_cliente_manutencao @relation(fields: [veiculo_manutencao_id], references: [id], onUpdate: Restrict, map: "fk_veiculo_manutencao")
}

model sucata_compras {
  id                    String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  data_compra           DateTime? @default(now()) @db.Timestamp(6)
  valor_compra          Decimal   @db.Decimal(10, 2)
  quantidade            Int       @default(1)
  responsavel_compra_id String    @db.Uuid
  cliente_vendedor_id   String    @db.Uuid
  clientes              clientes  @relation(fields: [cliente_vendedor_id], references: [id], onUpdate: Restrict, map: "fk_cliente_vendedor_id")
  usuarios              usuarios  @relation(fields: [responsavel_compra_id], references: [id], onUpdate: Restrict, map: "fk_responsavel_compra")
}

model sucata_estoque {
  id                    String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  marca_veiculo         marca_veiculo
  modelo_id             Int
  ano_fabricacao        Int
  ano_modelo            Int
  chassi                String         @unique @db.VarChar(100)
  cor                   cor?           @default(Preto)
  responsavel_compra_id String         @db.Uuid
  status_sucata         status_sucata? @default(Em_desmonte)
  data_entrada          DateTime?      @default(now()) @db.Timestamp(6)
  peca_estoque          peca_estoque[]
  usuarios              usuarios       @relation(fields: [responsavel_compra_id], references: [id], onUpdate: Restrict, map: "fk_responsavel_compra_id")
  modelos               modelos        @relation(fields: [modelo_id], references: [id], onUpdate: Restrict, map: "fk_sucata_modelo_marca_id")

  @@index([marca_veiculo, modelo_id], map: "idx_sucata_marca_modelo")
  @@index([modelo_id, marca_veiculo], map: "idx_sucata_modelo_marca")
}

model usuarios {
  id                        String                      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome                      String                      @unique @db.VarChar(100)
  email                     String                      @unique @db.VarChar(100)
  senha_hash                String
  cargo_usuario             cargo_usuario               @default(funcionario)
  setor_usuario             setor_usuario               @default(vendas)
  nivel_acesso              nivel_acesso                @default(Nivel_1)
  status_usuario            status_usuario              @default(ativo)
  data_admissao             DateTime                    @default(now()) @db.Timestamp(6)
  data_cadastro_sistema     DateTime                    @default(now()) @db.Timestamp(6)
  despesas                  despesas[]
  estoque_objetos_duraveis  estoque_objetos_duraveis[]
  estoque_objetos_genericos estoque_objetos_genericos[]
  peca_estoque              peca_estoque[]
  pedidos_vendas            pedidos_vendas[]
  servico_manutencao        servico_manutencao[]
  sucata_compras            sucata_compras[]
  sucata_estoque            sucata_estoque[]
}

model veiculos_cliente_manutencao {
  id                 String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  marca_veiculo      marca_veiculo
  modelo_id          Int
  cliente_id         String               @db.Uuid
  servico_manutencao servico_manutencao[]
  clientes           clientes             @relation(fields: [cliente_id], references: [id], onUpdate: Restrict, map: "fk_cliente_veiculo_manutencao")
  modelos            modelos              @relation(fields: [modelo_id], references: [id], onUpdate: Restrict, map: "fk_modelo_veiculo_manutencao")
}

enum cargo_usuario {
  administrador
  vendedor
  mecanico
  estoquista
  gerente
  desenvolvedor
  funcionario
  eletricista
  desmontador
  auxiliar_de_estoque     @map("auxiliar de estoque")
  auxiliar_administrativo @map("auxiliar administrativo")
  limpador
  outros
}

enum categoria_despesas {
  Despesas_operacionais    @map("Despesas operacionais")
  Despesas_administrativas @map("Despesas administrativas")
  Despesas_de_marketing    @map("Despesas de marketing")
  Despesas_de_pessoal      @map("Despesas de pessoal")
  Despesas_financeiras     @map("Despesas financeiras")
  Despesas_de_manuten__o   @map("Despesas de manutenção")
  Despesas_de_estoque      @map("Despesas de estoque")
  despesas_m_dicas         @map("despesas médicas")
  Outras_despesas          @map("Outras despesas")
}

enum categoria_peca {
  Motor_e_componentes            @map("Motor e componentes")
  El_trica_e_componentes         @map("Elétrica e componentes")
  Carroceria
  Sistema_de_ilumina__o_interior @map("Sistema de iluminação interior")
  Rodas_e_Pneus                  @map("Rodas e Pneus")
  Sistema_de_arrefecimento       @map("Sistema de arrefecimento")
  Sistema_de_combust_vel         @map("Sistema de combustível")
  Sistema_de_dire__o             @map("Sistema de direção")
  Sistema_de_embreagem           @map("Sistema de embreagem")
  Sistema_de_inje__o_eletr_nica  @map("Sistema de injeção eletrônica")
  Sistema_de_transmiss_o         @map("Sistema de transmissão")
  Sistema_de_suspens_o           @map("Sistema de suspensão")
  Sistema_de_freios              @map("Sistema de freios")
  Sistema_el_trico               @map("Sistema elétrico")
  Sistema_de_vidros_e_espelhos   @map("Sistema de vidros e espelhos")
  Sistema_de_ilumina__o_exterior @map("Sistema de iluminação exterior")
  Sistema_de_exaust_o            @map("Sistema de exaustão")
  Outros
}

enum cor {
  Preto
  Branco
  Prata
  Cinza
  Vermelho
  Azul
  Amarelo
  Verde
  Laranja
  Roxo
  Marrom
  Dourado
  grafite
  indefinida
  Outros
}

enum localizacao_peca {
  prateleira_1 @map("prateleira 1")
  prateleira_2 @map("prateleira 2")
  prateleira_3 @map("prateleira 3")
  prateleira_4 @map("prateleira 4")
  expositor
  outro
}

enum marca_veiculo {
  Fiat
  Volkswagen
  Chevrolet
  Hyundai
  Toyota
  Jeep
  Renault
  Honda
  Nissan
  BYD
  GWM
  Caoa_Chery    @map("Caoa Chery")
  Ford
  Peugeot
  Citro_n       @map("Citroën")
  Mitsubishi
  BMW
  Mercedes_Benz @map("Mercedes-Benz")
  Audi
  Volvo
  Land_Rover    @map("Land Rover")
  Porsche
  Kia
  Ram
}

enum metodo_pagamento {
  Pix
  Debito
  Credito
  Dinheiro
  cheque
}

enum nivel_acesso {
  Nivel_1
  NIvel_2
  Nivel_3
  Nivel_4
}

enum setor_prateleira {
  setor_A                @map("setor A")
  setor_B                @map("setor B")
  setor_C                @map("setor C")
  setor_D                @map("setor D")
  setor_E                @map("setor E")
  setor_F                @map("setor F")
  setor_G                @map("setor G")
  setor_H                @map("setor H")
  setor_I                @map("setor I")
  setor_J                @map("setor J")
  N_O_EST__NA_PRATELEIRA @map("NÃO ESTÁ NA PRATELEIRA")
}

enum setor_usuario {
  administrativo
  vendas
  manutencao
  estoque
  desenvolvimento
  limpeza
  outros
}

enum status_item {
  Disponivel
  Indisponivel
  Reservado
  Vendido
  Em_avalia__o    @map("Em avaliação")
  Rejeitado
  Aprovado
  Em_estoque      @map("Em estoque")
  Fora_de_estoque @map("Fora de estoque")
  Devolvido
}

enum status_manutencao {
  Pendente
  Em_andamento         @map("Em andamento")
  Conclu_da            @map("Concluída")
  Cancelada
  Aguardando_pe_as     @map("Aguardando peças")
  Aguardando_avalia__o @map("Aguardando avaliação")
  Rejeitada
  Aprovada
}

enum status_pedido {
  Autorizado
  Em_avalia__o   @map("Em avaliação")
  Rejeitado
  Nao_autorizado @map("Nao autorizado")
  cancelado
}

enum status_sucata {
  Em_desmonte          @map("Em desmonte")
  Em_manuten__o        @map("Em manutenção")
  Conclu_do            @map("Concluído")
  Indispon_vel         @map("Indisponível")
  Dispon_vel           @map("Disponível")
  Vendido
  Reservado
  Aguardando_avalia__o @map("Aguardando avaliação")
  Em_avalia__o         @map("Em avaliação")
  Rejeitado
  Aprovado
  Em_estoque           @map("Em estoque")
  Fora_de_estoque      @map("Fora de estoque")
}

enum status_usuario {
  ativo
  inativo
  suspenso
  pendente
  demitido
  aposentado
}

enum status_venda {
  Vendida
  Reservada
  Em_avalia__o   @map("Em avaliação")
  Nao_autorizada @map("Nao autorizada")
  cancelada
  Nao_disponivel @map("Nao disponivel")
}
