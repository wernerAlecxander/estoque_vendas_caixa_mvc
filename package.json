{
  "name": "estoque_vendas_caixa",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "preinstall": "pnpm dlx only-allow pnpm",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull",
    "dev": "sleep 3 && pnpm prisma:generate && next dev -H 0.0.0.0 -p 3100",
    "build": "pnpm prisma:generate && next build",
    "start": "next start -p 3100"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^1.17.0",
    "next": "^15.1.7",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.11.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "0.35.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp"
    ]
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.11.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5"
  }
}
