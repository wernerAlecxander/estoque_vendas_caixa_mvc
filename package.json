{
  "name": "estoque_vendas_caixa_mvc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.1",
  "scripts": {
    "prisma:generate": "pnpm prisma generate",
    "prisma:pull": "pnpm prisma db pull",
    "prisma:migrate": "pnpm prisma migrate dev",
    "prisma:studio": "pnpm prisma studio --port ${PRISMA_STUDIO_PORT:-5555} --browser none",
    "prisma:seed": "pnpm prisma db seed",
    "dev": "pnpm prisma:generate && next dev -H 0.0.0.0 -p 3100",
    "build": "pnpm prisma:generate && next build",
    "start": "next start -p 3100",
    "test": "pnpm prisma:generate && vitest",
    "test:run": "pnpm prisma:generate && vitest run"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "lucide-react": "^1.17.0",
    "next": "^16.2.10",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "0.35.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/config": "^7.8.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.19",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.17",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  }
}
